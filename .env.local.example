# Paystack Configuration
# Get your public key from: https://dashboard.paystack.com/#/settings/developer
# DO NOT share your secret key in this file
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here

# Optional: Analytics (Google Analytics, Mixpanel, etc.)
# NEXT_PUBLIC_GA_ID=G_XXXXXXXXXX

# Optional: API Base URL (if using external backend)
# NEXT_PUBLIC_API_URL=https://api.example.com

# Shipping Configuration (if integrating with shipping provider)
# SHIPPING_API_KEY=your_shipping_key_here

# Email Configuration (if sending transactional emails)
# SENDGRID_API_KEY=your_sendgrid_key_here
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Database (if using a backend database)
# DATABASE_URL=postgresql://user:password@localhost:5432/biyora

# Application Environment
# NODE_ENV=production
